  "keyFeatures": [
    "15 MCP tools for comprehensive Windows automation",
    "UI element detection via Windows Accessibility tree",
    "Screenshot capture with element annotation and grid overlay",
    "DOM extraction for clean browser automation",
    "Keyboard and mouse input simulation",
    "Multi-select and multi-edit operations",
    "Process and clipboard management",
    "Windows Registry access",
    "PowerShell command execution",
    "Local and remote VM deployment modes",
    "Support for multiple MCP clients (Claude Desktop, Perplexity, Gemini, etc.)",
    "Real-time interaction with 0.2-0.9s latency"
  ],
  "publicApiSurface": [
    "App - Launch, resize, and switch between applications",
    "PowerShell - Execute PowerShell commands",
    "FileSystem - File and directory operations (read, write, copy, move, delete, list, search, info)",
    "Snapshot - Capture desktop state with UI elements and screenshots",
    "Click - Perform mouse clicks at coordinates or UI elements",
    "Type - Type text at coordinates or UI elements",
    "Scroll - Scroll vertically or horizontally",
    "Move - Move mouse cursor or drag-and-drop",
    "Shortcut - Execute keyboard shortcuts",
    "Wait - Pause execution for specified duration",
    "Scrape - Fetch web page content from URL or DOM",
    "MultiSelect - Select multiple items with or without Ctrl",
    "MultiEdit - Enter text into multiple input fields",
    "Clipboard - Get or set Windows clipboard content",
    "Process - List or kill running processes",
    "Notification - Send Windows toast notifications",
    "Registry - Read, write, delete, or list Windows Registry values"
  ]
